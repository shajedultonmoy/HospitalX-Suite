PORT=5000
JWT_SECRET=hospitalx_super_secret_key
NODE_ENV=development

# Database Configuration
DB_DIALECT=sqlite
# For MySQL, use: DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=hospitalx_suite
# DB_USER=root
# DB_PASSWORD=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Database Sync (set to true to alter tables on start)
DB_SYNC_ALTER=true
